{
  "name": "ssh-reports-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "netlify": "netlify dev",
    "netlify:legacy": "netlify dev --envFiles .env.legacy",
    "setup-pdfjs": "mkdir -p public/lib/pdfjs && curl -L https://github.com/mozilla/pdf.js/releases/download/v5.7.284/pdfjs-5.7.284-dist.zip -o pdfjs.zip && unzip -o pdfjs.zip -d public/lib/pdfjs && rm pdfjs.zip",
    "build": "npm run setup-pdfjs && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node test/run-all.js",
    "test:unit": "node test/unit/utils.test.js",
    "test:integration": "node test/integration/api.test.js",
    "test:e2e": "node test/admin-status.test.js",
    "test:coverage": "node test/verify-api-coverage.js",
    "test:all": "node test/run-all.js"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-infinite-scroll-component": "^6.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "netlify-cli": "^24.0.0",
    "vite": "^6.4.2",
    "vite-plugin-compression": "^0.5.1",
    "@testing-library/react": "^14.0.0",
    "jest": "^29.0.0",
    "babel-jest": "^29.0.0",
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    }
  }
}
